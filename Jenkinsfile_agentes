pipeline {
    agent none

    environment {
        STAGING_STACK = "todo-list-aws-staging"
        REGION        = "us-east-1"
    }

    stages {

        stage('Get Code') {
            agent any
            steps {
                git branch: 'develop',
                    url: 'https://github.com/jugiros/todo-list-aws'
                echo "Codigo descargado de rama develop"
                sh 'whoami'
                sh 'hostname'
                stash name: 'code', includes: '**/*'
            }
        }

        stage('Static Test') {
            agent { label 'agente1' }
            steps {
                unstash 'code'
                sh 'whoami'
                sh 'hostname'
                sh '''
                    python3 -m flake8 src/ --exit-zero \
                        --format=pylint \
                        --output-file flake8-report.txt
                    python3 -m bandit -r src/ \
                        -f txt \
                        -o bandit-report.txt \
                        --exit-zero
                    echo "Informes generados: flake8-report.txt y bandit-report.txt"
                    cat flake8-report.txt
                    cat bandit-report.txt
                '''
            }
            post {
                always {
                    recordIssues(
                        tools: [flake8(pattern: 'flake8-report.txt')]
                    )
                    recordIssues(
                        tools: [pyLint(pattern: 'bandit-report.txt')]
                    )
                    archiveArtifacts artifacts: 'flake8-report.txt,bandit-report.txt',
                                     allowEmptyArchive: true
                }
            }
        }

        stage('Deploy') {
            agent any
            steps {
                unstash 'code'
                sh 'whoami'
                sh 'hostname'
                sh '''
                    sam build
                    sam deploy \
                        --config-env staging \
                        --no-confirm-changeset \
                        --no-fail-on-empty-changeset
                '''
                script {
                    env.BASE_URL = sh(
                        script: """
                            aws cloudformation describe-stacks \
                                --stack-name ${STAGING_STACK} \
                                --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' \
                                --region ${REGION} \
                                --output text
                        """,
                        returnStdout: true
                    ).trim()
                    echo "BASE_URL obtenida: ${env.BASE_URL}"
                    writeFile file: 'base_url.txt', text: env.BASE_URL
                    stash name: 'base-url', includes: 'base_url.txt'
                }
            }
        }

        stage('Rest Test') {
            agent { label 'agente2' }
            steps {
                unstash 'base-url'
                sh 'whoami'
                sh 'hostname'
                script {
                    env.BASE_URL = readFile('base_url.txt').trim()
                }
                sh "echo 'Ejecutando pytest contra: ${env.BASE_URL}'"
                sh "python3 -m pytest test/integration/todoApiTest.py -v --tb=short"
            }
        }

        stage('Promote') {
            agent any
            steps {
                unstash 'code'
                sh 'whoami'
                sh 'hostname'
                withCredentials([usernamePassword(
                    credentialsId: 'github-credentials',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        git config user.email "jugiros1@gmail.com"
                        git config user.name "jugiros"
                        git remote set-url origin https://${GIT_TOKEN}@github.com/jugiros/todo-list-aws.git
                        git fetch origin
                        git checkout master
                        git merge origin/develop --no-edit --strategy-option=theirs || true
                        git checkout master -- Jenkinsfile
                        git checkout master -- Jenkinsfile_agentes
                        git commit -m "chore: keep master Jenkinsfiles after merge" || true
                        git push origin master
                    '''
                }
            }
        }
    }

    post {
        always {
            node('built-in') {
                cleanWs()
            }
        }
        success {
            echo "Pipeline CI con agentes completado exitosamente"
        }
        failure {
            echo "Pipeline CI con agentes fallo - revisar logs"
        }
    }
}